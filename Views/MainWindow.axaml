<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MovieHunter.ViewModels"
        xmlns:models="using:MovieHunter.Models"
        xmlns:services="using:MovieHunter.Services"
        xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="780"
        x:Class="MovieHunter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MovieHunter"
        Width="1280" Height="780"
        MinWidth="800" MinHeight="500"
        Padding="0"
        WindowDecorations="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Hand cursor on every interactive control so clickable areas
             (poster cards, result buttons, transport buttons, sliders,
             caption buttons, checkboxes, radio buttons) visibly invite a
             click. -->
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- Hand cursor only on the slider track/thumb parts, not the
             full Slider bounding box (which extends beyond the visible
             line and triggered the pointer prematurely). -->
        <Style Selector="Slider /template/ Thumb">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Slider /template/ Track">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Position slider (in the transport bar, sitting on the dark
             video background) — explicit white-ish track + accent-colored
             filled portion. Track is kept consistently light on every
             theme; FluentTheme's Light variant otherwise feeds a darker
             SliderTrackFill resource through TemplateBinding which would
             make the track unreadable on pastel themes. -->
        <Style Selector="Slider#PositionSlider /template/ RepeatButton#PART_IncreaseButton /template/ ContentPresenter,
                         Slider#PositionSlider /template/ RepeatButton#PART_DecreaseButton /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Slider#PositionSlider /template/ Border#TrackBackground">
            <Setter Property="Height" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="Slider#PositionSlider /template/ Rectangle#PART_Indicator">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColorBrush}"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="RadiusX" Value="2"/>
            <Setter Property="RadiusY" Value="2"/>
        </Style>
        <!-- Flyout popup background resets to the default cursor — the
             global Button Hand style above otherwise bleeds through any
             button-like chrome the popup renders and makes the whole
             popup surface feel clickable. -->
        <Style Selector="FlyoutPresenter">
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Netflix-style transport buttons: no background at all, just
             the icon. On hover the icon scales up ~15% and the color stays
             white, no tint added behind it. Animated for the subtle zoom. -->
        <Style Selector="Button.transport, ToggleButton.transport">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe UI Emoji, sans-serif"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <!-- Outer button is Arrow; only the inner icon Border switches
                 to Hand so the cursor doesn't flip too early in the wide
                 padding around the icon. -->
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <Style Selector="Border.transport-icon">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.transport /template/ ContentPresenter,
                         ToggleButton.transport /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.transport:pointerover /template/ ContentPresenter,
                         ToggleButton.transport:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.transport:pressed /template/ ContentPresenter,
                         ToggleButton.transport:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.transport:pointerover,
                         ToggleButton.transport:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.3)"/>
        </Style>
        <Style Selector="TextBlock.time">
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Code, Consolas, Menlo, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>


        <!-- Theme pills (per design-system spec): pill-shaped RadioButton
             with a circular swatch + name. Active pill gets an accent
             border + accent-soft fill. Custom Template strips the default
             radio indicator dot. -->
        <Style Selector="RadioButton.theme-pill">
            <!-- Hardcoded neutral gray for idle / hover so unselected pills
                 stay rock-stable as you switch themes (DynamicResources
                 inside a Flyout sometimes lag behind merged-dictionary
                 swaps; using fixed alpha-grays bypasses that entirely). -->
            <Setter Property="Background" Value="#10808080"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6,14,6"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="RadioButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- Hover: ONLY the background changes (slightly stronger gray). -->
        <Style Selector="RadioButton.theme-pill:pointerover">
            <Setter Property="Background" Value="#22808080"/>
        </Style>
        <!-- Selected pill: colors are set imperatively in code-behind
             (UpdateActivePill) right after App.ApplyTheme runs, so the
             border + bg always reflect the *just-applied* theme. The
             previous Style-based approach via DynamicResource lagged
             inside Flyout content. -->

        <!-- Theme-pill swatch ring: hardcoded subtle dark stroke so the
             swatch dot is consistently defined on light and dark
             backgrounds (theme-aware brush lagged behind merged-dict
             swaps inside the Flyout). -->
        <Style Selector="Ellipse.swatch">
            <Setter Property="Stroke" Value="#1F000000"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <!-- Result-row action buttons (Play / Open source) — transparent
             at all states; only the Path stroke flips to the active
             theme accent on pointer-over. Same approach as the sidebar
             nav. -->
        <Style Selector="Button.result-action /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.result-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.result-action:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.result-action Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.result-action:pointerover Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <!-- Same idle / hover handling for the My-List toggle's Ellipse
             (the plus-circle / check-circle icons use both Ellipse and
             Path; Style only matched Path before). -->
        <Style Selector="Button.result-action Ellipse">
            <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.result-action:pointerover Ellipse">
            <Setter Property="Stroke" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>

        <!-- Search-result rows: 10px corner radius, surface-2 fill on
             hover, accent-soft fill when selected. Matches the design
             system's .mh-result-row spec. -->
        <Style Selector="ListBox.results ListBoxItem">
            <!-- 8px L/T/B + 16px right so the action buttons sit clear of
                 the 10px overlay scrollbar (with 6px breathing room). -->
            <Setter Property="Padding" Value="8,8,16,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="ListBox.results ListBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="ListBox.results ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
        </Style>

        <!-- Sidebar nav-rail buttons: 44×44, fully transparent, no hover
             background — only the icon stroke flips to the active theme's
             accent on pointer-over. -->
        <Style Selector="Button.nav">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="Button.nav /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Path stroke retints to the theme accent on pointer-over.
             Stroke is set on a Style (not inline on the Path) so the
             :pointerover override can win — inline values have higher
             priority than Style setters. -->
        <Style Selector="Button.nav Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.nav:pointerover Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <!-- Active tab: same accent stroke as hover, persistent so the
             user can see at a glance which sidebar tab they're on. -->
        <Style Selector="Button.nav.active Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>

        <!-- Flat progress bar for recent-watched cards. The default
             FluentTheme ProgressBar template adds internal padding /
             rounded corners that eat both ends of a 3-px-tall bar
             (looked like the first / last ~10% never lit up). This
             template is just a track Border + a left-anchored
             PART_Indicator whose width Avalonia sets directly from
             Value, so the fill maps exactly to 0–100%. -->
        <Style Selector="ProgressBar.recent-progress">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#22808080"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorBrush}"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Border x:Name="PART_Indicator"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Primary CTA — accent fill, pill shape, white label. From the
             design system: filled accent, 999 corner radius, medium weight,
             14px, ~24×8 padding. -->
        <Style Selector="Button.primary /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="24,8"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1Brush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark2Brush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Recently-watched card: suppress the default button hover
             overlay — hover styling lives on the inner poster Border
             below so the accent-colored outline hugs the poster only
             (the progress bar beneath stays un-framed). -->
        <Style Selector="Button.recent-card /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.recent-card:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.recent-card:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Poster always reserves a 2px border (transparent) so hovering
             doesn't shift layout; pointer-over on the parent button swaps
             in the current theme accent. -->
        <Style Selector="Border.poster">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Pointer-over swap is handled in code-behind (Poster_PointerEntered /
             Poster_PointerExited) — descendant selectors don't reliably
             reach into ItemTemplate content. -->

        <!-- Custom title-bar caption buttons. Transparent by default so
             they inherit the title-bar background; hover highlights with a
             subtle overlay, with close going Windows-red on hover. -->
        <Style Selector="Button.caption">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <!-- Title-bar buttons keep the default arrow cursor — feels
                 more like native window chrome than an in-app control. -->
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <!-- Minimize / maximize use FluentTheme's default Button hover
             background (same as the theme button) — no explicit override
             needed. Close still has its own red rule below. -->
        <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Back arrow in the video overlay: no hover tint at all; subtle
             scale-up on hover to match the transport-bar icons. -->
        <Style Selector="Button.back">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <Style Selector="Button.back /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.back:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.back:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.back:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.3)"/>
        </Style>

        <!-- Search bar input fields: pill shape, subtle tinted fill, no
             visible border in idle / hover; accent-colored border only
             when focused. Mirrors the design-system spec. -->
        <Style Selector="TextBox.search-input">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="TextBox.search-input /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBox.search-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.search-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <Style Selector="TextBox.search-input:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>

        <!-- Same look for NumericUpDown. FluentTheme's inner ButtonSpinner
             has its own per-state Background that otherwise wins over the
             outer NumericUpDown's TemplateBinding, so we target it directly
             via /template/ for idle / hover / focus. -->
        <Style Selector="NumericUpDown.search-input">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="NumericUpDown.search-input /template/ ButtonSpinner">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="NumericUpDown.search-input:pointerover /template/ ButtonSpinner">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="NumericUpDown.search-input:focus-within /template/ ButtonSpinner">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <!-- Suppress the inner TextBox's own border/background entirely.
             FluentTheme repaints it on hover/focus with a rectangular
             corner radius, which broke the pill shape and added a
             stray rectangle outline over the outer ButtonSpinner. -->
        <Style Selector="NumericUpDown.search-input TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- v2 — My-List poster chip (top-right of poster cards).
             Transparent background — the icon sits directly on the
             poster, sized large enough to read against any frame. -->
        <Style Selector="Button.poster-chip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.poster-chip /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.poster-chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Glyph color lives in styles (not inline on each Path) so the
             :pointerover override actually wins — inline values would
             beat any style setter. PosterChipStrokeBrush is theme-defined
             (white on dark themes, black on light pastel themes) so the
             icons stay legible against the title-strip surface. Hover
             still flips to the theme accent (red for Netflix, etc.). -->
        <Style Selector="Button.poster-chip Path">
            <Setter Property="Stroke" Value="{DynamicResource PosterChipStrokeBrush}"/>
        </Style>
        <Style Selector="Button.poster-chip:pointerover Path">
            <Setter Property="Stroke" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <!-- Filled icons inside the chip / result-action buttons (e.g. the
             play triangle). The default Path styles above set Stroke on
             every Path; the .filled selector overrides Stroke to
             Transparent and drives the same color via Fill instead, so
             the hover-to-accent transition still works. -->
        <Style Selector="Button.poster-chip Path.filled">
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="Fill" Value="{DynamicResource PosterChipStrokeBrush}"/>
        </Style>
        <Style Selector="Button.poster-chip:pointerover Path.filled">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>
        <Style Selector="Button.result-action Path.filled">
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.result-action:pointerover Path.filled">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColorBrush}"/>
        </Style>

        <!-- Hover-only action row inside the title strip on recent +
             my-list cards. Toggling the parent StackPanel.IsVisible (not
             each Button) means the row collapses out of layout cleanly,
             leaving the "Currently playing" badge below it flush against
             Source when no buttons are showing. -->
        <Style Selector="Button.recent-card StackPanel.action-row">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Button.recent-card:pointerover StackPanel.action-row">
            <Setter Property="IsVisible" Value="True"/>
        </Style>

        <!-- Title/Source strip on the recent + my-list cards. Both
             brushes track the active theme: PosterTitleStripBrush is the
             theme's elevated surface at ~80% opacity (poster reads
             through at rest); PosterTitleStripHoverBrush is fully opaque
             (solid backdrop on hover). Each theme override file provides
             the values — dark themes tint to their surface color; light
             themes stay near-black so the white Title/Source text stays
             readable. -->
        <Style Selector="Border.title-strip">
            <Setter Property="Background" Value="{DynamicResource PosterTitleStripBrush}"/>
        </Style>
        <Style Selector="Button.recent-card:pointerover Border.title-strip">
            <Setter Property="Background" Value="{DynamicResource PosterTitleStripHoverBrush}"/>
        </Style>

        <!-- v2 — Result-row meta (Source / MetaLine). Reuses the same
             per-theme PosterSourceTextBrush as the poster-strip source
             line — pure white at ~67% alpha on dark themes, near-black
             at ~67% alpha on light themes. Avoids FluentTheme's baked-in
             opacity dimming that makes TextFillColorSecondaryBrush look
             too dark on dark surfaces. -->
        <Style Selector="TextBlock.result-meta">
            <Setter Property="Foreground" Value="{DynamicResource PosterSourceTextBrush}"/>
        </Style>

        <!-- v2 — Modern slim scrollbar. We replace the FluentTheme
             ScrollBar template entirely (vertical + horizontal) so the
             thumb is a simple Border filled with the active theme
             accent — FluentTheme's default Thumb template paints
             through internal resource brushes that ignore Background
             setters and were swallowing our accent color. -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AllowAutoHide" Value="False"/>
        </Style>
        <!-- Hover: brighten only the thumb (the draggable part) — the
             unscrolled track lane stays at its faint resting opacity. -->
        <Style Selector="ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <!-- Direct thumb drag: Avalonia keeps Thumb in :pressed state
             for the whole drag (pointer capture survives leaving the
             bar), so this style holds the brighter look while the user
             scrubs even far outside the scrollbar. -->
        <Style Selector="ScrollBar /template/ Thumb:pressed">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <!-- Track-lane drag: "scrolling" class is toggled on the thumb
             from code-behind while a lane-click drag is in progress.
             Mirrors the :pressed behavior for thumb drags but for the
             other entry point. -->
        <Style Selector="Thumb.scrolling">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ScrollBar:vertical">
            <!-- 14 px control width gives a forgiving hit target while
                 the lane and thumb stay slim (6 px wide, centered) via
                 their Margin — visually unchanged, but clicks within
                 a few pixels of the bar still register. -->
            <Setter Property="Width" Value="14"/>
            <Setter Property="MinWidth" Value="14"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ScrollBar">
                    <!-- Outer Border applies the 4 px top/bottom inset
                         so the rounded caps clear the panel's rounded
                         corner clip. Done at the OUTER level (not on
                         the Thumb) because Margin on the Thumb breaks
                         Track's value-to-position mapping — the Track
                         needs the Thumb to be at its natural bounds. -->
                    <Border Padding="0,4">
                        <!-- Pointer handlers live on the Grid (full 14 px
                             hit area) instead of the slim 6 px lane
                             Border. Otherwise clicks on the transparent
                             gutter that pads the visual lane wouldn't
                             register. The Thumb marks its own
                             PointerPressed handled, so thumb-direct
                             drags still go through Avalonia's native
                             Track logic without hitting this handler. -->
                        <Grid Background="{TemplateBinding Background}"
                              PointerPressed="OnScrollBarTrackClick"
                              PointerMoved="OnScrollBarTrackPointerMoved"
                              PointerReleased="OnScrollBarTrackPointerReleased">
                            <!-- Faint track lane that stays visible
                                 whether or not the thumb covers it. -->
                            <Border Margin="4,0"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    CornerRadius="3"
                                    Opacity="0.15"/>
                            <Track Orientation="Vertical"
                                   IsDirectionReversed="True"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.Thumb>
                                    <Thumb Margin="4,0" MinHeight="24" Opacity="0.75">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource SystemAccentColorBrush}"
                                                        CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="14"/>
            <Setter Property="MinHeight" Value="14"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ScrollBar">
                    <Border Padding="4,0">
                        <Grid Background="{TemplateBinding Background}"
                              PointerPressed="OnScrollBarTrackClick"
                              PointerMoved="OnScrollBarTrackPointerMoved"
                              PointerReleased="OnScrollBarTrackPointerReleased">
                            <Border Margin="0,4"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    CornerRadius="3"
                                    Opacity="0.15"/>
                            <Track Orientation="Horizontal"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.Thumb>
                                    <Thumb Margin="0,4" MinWidth="24" Opacity="0.75">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource SystemAccentColorBrush}"
                                                        CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Custom title bar: MovieHunter name + theme picker on the left,
             our own minimize / maximize / close on the right. Background is
             transparent so it picks up the window (theme) background. The
             Grid handles dragging via PointerPressed; clicks on buttons are
             consumed by the buttons themselves so drag only triggers on
             empty space. -->
        <Grid Grid.Row="0" x:Name="TitleBar" Height="32"
              Background="Transparent"
              ColumnDefinitions="Auto,Auto,*,Auto"
              PointerPressed="TitleBar_PointerPressed">
            <TextBlock Grid.Column="0"
                       Text="MovieHunter"
                       FontWeight="SemiBold"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="12,0,8,0"/>
            <Button Grid.Column="1"
                    ToolTip.Tip="Themes"
                    Width="28" Height="28"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Cursor="Arrow"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="ThemeBtn_Click">
                <Viewbox Width="14" Height="14">
                    <Grid Width="24" Height="24">
                        <!-- Lucide palette — stroke body + 4 filled paint dots. -->
                        <Path Data="M 12 2 C 6.5 2 2 6.5 2 12 s 4.5 10 10 10 c 0.926 0 1.648 -0.746 1.648 -1.688 0 -0.437 -0.18 -0.835 -0.437 -1.125 -0.29 -0.289 -0.438 -0.652 -0.438 -1.125 a 1.64 1.64 0 0 1 1.668 -1.668 h 1.996 c 3.051 0 5.555 -2.503 5.555 -5.554 C 21.965 6.012 17.461 2 12 2 z"
                              Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" StrokeJoin="Round"
                              Fill="Transparent"/>
                        <Path Data="M 14.5 6.5 a 1 1 0 1 1 -2 0 a 1 1 0 0 1 2 0 z M 18.5 10.5 a 1 1 0 1 1 -2 0 a 1 1 0 0 1 2 0 z M 9.5 7.5 a 1 1 0 1 1 -2 0 a 1 1 0 0 1 2 0 z M 7.5 12.5 a 1 1 0 1 1 -2 0 a 1 1 0 0 1 2 0 z"
                              Fill="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </Grid>
                </Viewbox>
            </Button>
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Classes="caption"
                        Click="Minimize_Click"
                        ToolTip.Tip="Minimize">
                    <Viewbox Width="12" Height="12">
                        <Grid Width="24" Height="24">
                            <Path Data="M 5 12 H 19"
                                  Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineCap="Round"/>
                        </Grid>
                    </Viewbox>
                </Button>
                <Button Classes="caption"
                        Click="MaxRestore_Click"
                        ToolTip.Tip="Maximize">
                    <Viewbox Width="12" Height="12">
                        <Grid Width="24" Height="24">
                            <Path Data="M 4 4 H 20 V 20 H 4 Z"
                                  Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>
                <Button Classes="caption close"
                        Click="CloseWindow_Click"
                        ToolTip.Tip="Close">
                    <Viewbox Width="12" Height="12">
                        <Grid Width="24" Height="24">
                            <Path Data="M 18 6 L 6 18 M 6 6 L 18 18"
                                  Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineCap="Round"/>
                        </Grid>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>

    <!-- Body: 64px sidebar nav rail + main content. Per the design system,
         the rail surfaces the three intent buckets (Search / Recently
         watched / Settings) without breaking the existing window layout.
         BodyGrid is named so ToggleFullscreen can collapse column 0 to
         zero (the column is fixed-width, so hiding SidebarRail alone
         would leave an empty 64px slot). -->
    <Grid Grid.Row="1" x:Name="BodyGrid" ColumnDefinitions="64,*">

        <Border Grid.Column="0" x:Name="SidebarRail"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Spacing="4" Margin="0,12">
                <!-- Logo mark — stroke-only rounded square + play triangle
                     in the active theme's accent. Matches assets/logo-mark.svg
                     from the design system. -->
                <Viewbox Width="32" Height="32"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8">
                    <Grid Width="32" Height="32">
                        <Path Data="M 3 3 H 26 a 3 3 0 0 1 3 3 V 26 a 3 3 0 0 1 -3 3 H 6 a 3 3 0 0 1 -3 -3 Z M 13 11 L 22 16 L 13 21 Z"
                              Stroke="{DynamicResource SystemAccentColorBrush}"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" StrokeJoin="Round"
                              Fill="Transparent"/>
                    </Grid>
                </Viewbox>
                <Button Classes="nav"
                        x:Name="NavSearchBtn"
                        Click="NavSearch_Click"
                        ToolTip.Tip="Search">
                    <Viewbox Width="20" Height="20">
                        <Grid Width="24" Height="24">
                            <Path Data="M 11 3 a 8 8 0 1 0 0 16 a 8 8 0 1 0 0 -16 M 21 21 L 16.65 16.65"
                                  StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>
                <Button Classes="nav"
                        x:Name="NavRecentBtn"
                        Click="NavRecent_Click"
                        ToolTip.Tip="Recently watched">
                    <Viewbox Width="20" Height="20">
                        <Grid Width="24" Height="24">
                            <Path Data="M 12 2 a 10 10 0 1 0 0 20 a 10 10 0 1 0 0 -20 M 12 6 V 12 L 16 14"
                                  StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>
                <!-- My List nav: design-system v2 list-add glyph
                     (plus-in-circle). Stroke comes from the Button's
                     Foreground via Path Stroke binding, so the .nav.active
                     style flips it to the accent. -->
                <Button Classes="nav"
                        x:Name="NavMyListBtn"
                        Click="NavMyList_Click"
                        ToolTip.Tip="My list">
                    <Viewbox Width="20" Height="20">
                        <Grid Width="24" Height="24">
                            <!-- Saved-state check (same glyph as the
                                 "in My list" chip on poster cards). -->
                            <Path Data="M 4 12.5 L 9 17.5 L 20 6.5"
                                  StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>
                <Button Classes="nav"
                        x:Name="SettingsBtn"
                        Click="NavSettings_Click"
                        ToolTip.Tip="Settings">
                    <Viewbox Width="20" Height="20">
                        <Grid Width="24" Height="24">
                            <!-- Lucide settings (gear). -->
                            <Path Data="M 12.22 2 h -0.44 a 2 2 0 0 0 -2 2 v 0.18 a 2 2 0 0 1 -1 1.73 l -0.43 0.25 a 2 2 0 0 1 -2 0 l -0.15 -0.08 a 2 2 0 0 0 -2.73 0.73 l -0.22 0.38 a 2 2 0 0 0 0.73 2.73 l 0.15 0.1 a 2 2 0 0 1 1 1.72 v 0.51 a 2 2 0 0 1 -1 1.74 l -0.15 0.09 a 2 2 0 0 0 -0.73 2.73 l 0.22 0.38 a 2 2 0 0 0 2.73 0.73 l 0.15 -0.08 a 2 2 0 0 1 2 0 l 0.43 0.25 a 2 2 0 0 1 1 1.73 V 20 a 2 2 0 0 0 2 2 h 0.44 a 2 2 0 0 0 2 -2 v -0.18 a 2 2 0 0 1 1 -1.73 l 0.43 -0.25 a 2 2 0 0 1 2 0 l 0.15 0.08 a 2 2 0 0 0 2.73 -0.73 l 0.22 -0.39 a 2 2 0 0 0 -0.73 -2.73 l -0.15 -0.08 a 2 2 0 0 1 -1 -1.74 v -0.5 a 2 2 0 0 1 1 -1.74 l 0.15 -0.09 a 2 2 0 0 0 0.73 -2.73 l -0.22 -0.38 a 2 2 0 0 0 -2.73 -0.73 l -0.15 0.08 a 2 2 0 0 1 -2 0 l -0.43 -0.25 a 2 2 0 0 1 -1 -1.73 V 4 a 2 2 0 0 0 -2 -2 z M 12 15 a 3 3 0 1 0 0 -6 a 3 3 0 0 0 0 6 z"
                                  StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>

    <Grid Grid.Column="1" x:Name="RootGrid" RowDefinitions="Auto,*" Margin="12">

        <Grid x:Name="SearchBar" Grid.Row="0" ColumnDefinitions="*,110,Auto">
            <TextBox Grid.Column="0" x:Name="TitleBox" Classes="search-input"
                     Margin="0,0,8,0"
                     PlaceholderText="Title"
                     Text="{Binding Title}"/>
            <TextBox Grid.Column="1" x:Name="YearBox" Classes="search-input"
                     Margin="0,0,8,0"
                     PlaceholderText="Year"
                     Text="{Binding Year}"/>
            <Button  Grid.Column="2" Classes="primary" MinWidth="90"
                     Command="{Binding SearchCommand}"
                     IsEnabled="{Binding !IsSearching}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Viewbox Width="16" Height="16">
                        <Grid Width="24" Height="24">
                            <Path Data="M 11 3 a 8 8 0 1 0 0 16 a 8 8 0 1 0 0 -16 M 21 21 L 16.65 16.65"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                    <TextBlock Text="Search" Foreground="White" FontWeight="Medium"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" x:Name="ContentGrid" Margin="0,12,0,0">
            <!-- Default: results panel takes the full content width, video
                 stage column is collapsed. ShowPlaybackView swaps these
                 (Column 0 = 0, Column 1 = *) when a movie starts playing. -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="ResultsPanel" Grid.Column="0"
                    Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="6,12,6,12"
                    ClipToBounds="True"
                    BoxShadow="0 4 16 0 #11281E50">
                <Grid>
                    <ListBox Classes="results"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedResult}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,16,0"
                             KeyboardNavigation.TabNavigation="Continue">
                    <ListBox.Styles>
                        <!-- Tab should skip the row itself and go directly
                             to the buttons inside the row. -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="IsTabStop" Value="False"/>
                        </Style>
                    </ListBox.Styles>
                    <!-- Disable virtualization so all result rows are
                         materialized — required for Tab to reach buttons
                         in rows that are currently scrolled out of view. -->
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:VideoResult">
                            <Grid Margin="1" ColumnDefinitions="Auto,*,Auto">
                                <!-- Poster from hdfilme (2:3 aspect). -->
                                <Border Grid.Column="0" Width="60" Height="90"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                                        CornerRadius="6"
                                        ClipToBounds="True">
                                    <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="Medium"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Source}"
                                               Classes="result-meta"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding MetaLine}"
                                               Classes="result-meta"
                                               FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Button Classes="result-action"
                                            Tag="{Binding}"
                                            Click="PlayResult_Click"
                                            ToolTip.Tip="Play this result (Enter)"
                                            Width="40" Height="40" Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center">
                                        <Viewbox Width="22" Height="22">
                                            <Grid Width="24" Height="24">
                                                <Path Classes="filled"
                                                      Data="M 7.5 4.21 C 6.83 3.79 6 4.27 6 5.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"/>
                                            </Grid>
                                        </Viewbox>
                                    </Button>
                                    <!-- v2 — Add to / remove from My List.
                                         Same toggle as the poster chip; the
                                         result-action class handles idle /
                                         hover stroke styling for both Path
                                         and Ellipse. The saved-state inner
                                         glyphs use inline accent stroke so
                                         "saved" reads even without hover. -->
                                    <Button Classes="result-action"
                                            Tag="{Binding}"
                                            Click="ToggleMyList_Click"
                                            ToolTip.Tip="Add to My List"
                                            Width="40" Height="40" Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center">
                                        <Grid>
                                            <Viewbox Width="22" Height="22"
                                                     IsVisible="{Binding !IsInMyList}">
                                                <Grid Width="24" Height="24">
                                                    <Path Data="M 12 4 V 20 M 4 12 H 20"
                                                          StrokeThickness="2"
                                                          StrokeLineCap="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Viewbox>
                                            <Viewbox Width="22" Height="22"
                                                     IsVisible="{Binding IsInMyList}">
                                                <Grid Width="24" Height="24">
                                                    <Path Data="M 4 12.5 L 9 17.5 L 20 6.5"
                                                          Stroke="{DynamicResource SystemAccentColorBrush}"
                                                          StrokeThickness="2"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Viewbox>
                                        </Grid>
                                    </Button>
                                    <Button Classes="result-action"
                                            Tag="{Binding}"
                                            Click="OpenSource_Click"
                                            ToolTip.Tip="Open source page in browser (Enter)"
                                            Width="40" Height="40" Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center">
                                        <Viewbox Width="22" Height="22">
                                            <Grid Width="24" Height="24">
                                                <Path Data="M 15 3 h 6 v 6 M 10 14 L 21 3 M 18 13 v 6 a 2 2 0 0 1 -2 2 H 5 a 2 2 0 0 1 -2 -2 V 8 a 2 2 0 0 1 2 -2 h 6"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round" StrokeJoin="Round"
                                                      Fill="Transparent"/>
                                            </Grid>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel x:Name="SearchResultsEmptyLabel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="14"
                            IsHitTestVisible="False">
                    <!-- Icon swap: magnifying glass when idle, spinning
                         loader-circle while a search is in flight. -->
                    <Grid Width="48" Height="48" HorizontalAlignment="Center">
                        <Viewbox IsVisible="{Binding !IsSearching}"
                                 Opacity="0.7">
                            <Grid Width="24" Height="24">
                                <!-- Lucide search — same magnifying glass
                                     as the sidebar nav icon. -->
                                <Path Data="M 11 3 a 8 8 0 1 0 0 16 a 8 8 0 1 0 0 -16 M 21 21 L 16.65 16.65"
                                      Stroke="{DynamicResource SystemAccentColorBrush}"
                                      StrokeThickness="1.8"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Fill="Transparent"/>
                            </Grid>
                        </Viewbox>
                        <Viewbox IsVisible="{Binding IsSearching}">
                            <Grid Width="24" Height="24"
                                  x:Name="SearchEmptySpinner"
                                  Classes.searching="{Binding IsSearching}"
                                  RenderTransformOrigin="50%,50%">
                                <Grid.Styles>
                                    <!-- Gate the rotation on the .searching
                                         class (bound to IsSearching) — same
                                         pattern as LoadingSpinner. Avalonia's
                                         INFINITE animations keep invalidating
                                         their target even when the parent
                                         is hidden / collapsed, which leaks a
                                         phantom square into the video area
                                         when playback starts from this tab.
                                         Detaching the animation entirely
                                         while not searching avoids that. -->
                                    <Style Selector="Grid#SearchEmptySpinner.searching">
                                        <Style.Animations>
                                            <Animation Duration="0:0:1"
                                                       IterationCount="INFINITE">
                                                <KeyFrame Cue="0%">
                                                    <Setter Property="RotateTransform.Angle" Value="0"/>
                                                </KeyFrame>
                                                <KeyFrame Cue="100%">
                                                    <Setter Property="RotateTransform.Angle" Value="360"/>
                                                </KeyFrame>
                                            </Animation>
                                        </Style.Animations>
                                    </Style>
                                </Grid.Styles>
                                <Grid.RenderTransform>
                                    <RotateTransform/>
                                </Grid.RenderTransform>
                                <Path Data="M 21 12 a 9 9 0 1 1 -6.219 -8.56"
                                      Stroke="{DynamicResource SystemAccentColorBrush}"
                                      StrokeThickness="2.4"
                                      StrokeLineCap="Round"
                                      Fill="Transparent"/>
                            </Grid>
                        </Viewbox>
                    </Grid>
                    <TextBlock Text="Enter a title and click Search."
                               IsVisible="{Binding !IsSearching}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="320"
                               FontSize="14"
                               Opacity="0.7"/>
                    <TextBlock Text="Searching…"
                               IsVisible="{Binding IsSearching}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="320"
                               FontSize="14"
                               Opacity="0.7"/>
                </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Border x:Name="VideoBorder" Background="Transparent" CornerRadius="0" ClipToBounds="True">
                    <Grid x:Name="VideoOverlayRoot" Background="Transparent"
                          Focusable="True">
                        <Image x:Name="VideoImage" Stretch="Uniform" IsVisible="False"/>

                        <!-- Loading overlay: shown from the moment the user
                             picks a movie until the player's Playing event
                             fires. Lucide loader-circle arc rotates via an
                             infinite Avalonia animation. No background
                             wash — the white spinner stands on its own
                             against the video surface so there's nothing
                             translucent left to "fade" when we hide it. -->
                        <Grid x:Name="LoadingOverlay"
                              IsHitTestVisible="False"
                              IsVisible="False">
                            <Viewbox Width="48" Height="48"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid Width="24" Height="24"
                                      x:Name="LoadingSpinner"
                                      RenderTransformOrigin="50%,50%">
                                    <Grid.Styles>
                                        <!-- Animation only runs when the
                                             ".spinning" class is present.
                                             Avalonia's INFINITE animations
                                             keep invalidating their target
                                             even when the parent is
                                             IsVisible=False, which can leak
                                             phantom rendering — gating on a
                                             class detaches the animation
                                             entirely while not loading. -->
                                        <Style Selector="Grid#LoadingSpinner.spinning">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1"
                                                           IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="RotateTransform.Angle" Value="0"/>
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="RotateTransform.Angle" Value="360"/>
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Grid.Styles>
                                    <Grid.RenderTransform>
                                        <RotateTransform/>
                                    </Grid.RenderTransform>
                                    <!-- Lucide loader-circle arc — three-
                                         quarter circle with rounded ends.
                                         Stroke uses the active theme's
                                         accent so it picks up the user's
                                         theme color. -->
                                    <Path Data="M 21 12 a 9 9 0 1 1 -6.219 -8.56"
                                          Stroke="{DynamicResource SystemAccentColorBrush}"
                                          StrokeThickness="2.4"
                                          StrokeLineCap="Round"
                                          Fill="Transparent"/>
                                </Grid>
                            </Viewbox>
                        </Grid>

                        <!-- Center HUD: a Netflix-style ephemeral indicator
                             that flashes a big icon (play / pause / skip /
                             volume) on a translucent black pill whenever the
                             user fires the corresponding action. Driven from
                             code-behind via PulsePlayerHud — Opacity rides a
                             200 ms transition for the fade in / out, so the
                             user sees a quick reassurance pulse without the
                             chrome staying on screen. -->
                        <Border x:Name="PlayerHud"
                                Width="88" Height="88"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0"
                                Background="#80000000"
                                CornerRadius="999"
                                IsHitTestVisible="False"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                </Transitions>
                            </Border.Transitions>
                            <Viewbox Width="56" Height="56"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid Width="24" Height="24">
                                    <Path x:Name="HudPlayIcon"
                                          Data="M 7.5 3.21 C 6.83 2.79 6 3.27 6 4.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"
                                          Fill="White"
                                          IsVisible="False"/>
                                    <Path x:Name="HudPauseIcon"
                                          Data="M 8 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z M 16 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z"
                                          Fill="White"
                                          IsVisible="False"/>
                                    <Path x:Name="HudBackIcon"
                                          Data="M 3 12 a 9 9 0 1 0 3 -7.7 L 3 8 M 3 3 v 5 h 5"
                                          Stroke="White" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"
                                          Fill="Transparent"
                                          IsVisible="False"/>
                                    <Path x:Name="HudForwardIcon"
                                          Data="M 21 12 a 9 9 0 1 1 -3 -7.7 L 21 8 M 21 3 v 5 h -5"
                                          Stroke="White" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"
                                          Fill="Transparent"
                                          IsVisible="False"/>
                                    <Path x:Name="HudVolumeIcon"
                                          Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 15.54 8.46 a 5 5 0 0 1 0 7.07 M 19.07 4.93 a 10 10 0 0 1 0 14.14"
                                          Stroke="White" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"
                                          Fill="Transparent"
                                          IsVisible="False"/>
                                    <Path x:Name="HudMuteIcon"
                                          Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 22 9 l -6 6 M 16 9 l 6 6"
                                          Stroke="White" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"
                                          Fill="Transparent"
                                          IsVisible="False"/>
                                </Grid>
                            </Viewbox>
                        </Border>

                        <!-- Top gradient strip: dark at the top, gently
                             fades to transparent over ~200px with an
                             intermediate stop so the transition is smooth
                             (no visible band). Purely decorative. -->
                        <Border x:Name="TopGradient"
                                VerticalAlignment="Top"
                                Height="200"
                                IsHitTestVisible="False"
                                IsVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Offset="0" Color="#E6000000"/>
                                    <GradientStop Offset="0.5" Color="#66000000"/>
                                    <GradientStop Offset="1" Color="#00000000"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Bottom gradient strip: mirrors the top — fades
                             from transparent at the top to dark at the
                             bottom over ~280px (transport controls sit in
                             the darkest part). -->
                        <Border x:Name="BottomGradient"
                                VerticalAlignment="Bottom"
                                Height="280"
                                IsHitTestVisible="False"
                                IsVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Offset="0" Color="#00000000"/>
                                    <GradientStop Offset="0.5" Color="#66000000"/>
                                    <GradientStop Offset="1" Color="#E6000000"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Back arrow (Netflix-style): stops playback and
                             returns to the recently-watched overlay. Hidden
                             until a movie is loaded. -->
                        <Button x:Name="BackButton"
                                Classes="back"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="16"
                                Width="52" Height="52"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="White"
                                FontSize="30"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                IsVisible="False"
                                Focusable="False"
                                IsTabStop="False"
                                Click="Back_Click">
                            <Border Classes="transport-icon">
                                <Viewbox Width="28" Height="28">
                                    <Grid Width="24" Height="24">
                                        <Path Data="M 12 19 L 5 12 L 12 5 M 19 12 H 5"
                                              Stroke="White" StrokeThickness="1.8"
                                              StrokeLineCap="Round" StrokeJoin="Round"
                                              Fill="Transparent"/>
                                    </Grid>
                                </Viewbox>
                            </Border>
                        </Button>

                        <TextBlock x:Name="CurrentMovieTitle"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="60,31,60,0"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="600"
                                   IsVisible="False"/>

                        <Border x:Name="TransportBarContainer"
                                VerticalAlignment="Bottom"
                                Padding="4,8,4,12"
                                Background="Transparent"
                                IsVisible="False">
                            <!-- Netflix-style two-row transport:
                                 Row 0: position slider + remaining time
                                 Row 1: play/pause, -10s, +10s, mute+volume, fullscreen
                                 Play button starts flush-left with the slider. -->
                            <Grid RowDefinitions="Auto,Auto">
                                <Grid Grid.Row="0" x:Name="TimelineRow"
                                      ColumnDefinitions="*,Auto"
                                      Margin="12,0,12,0">
                                    <Slider   Grid.Column="0" x:Name="PositionSlider"
                                              Minimum="0" Maximum="1000" Value="0"
                                              Focusable="False" IsTabStop="False"
                                              VerticalAlignment="Center">
                                        <!-- Scoped resource overrides: the
                                             unplayed track stays a consistent
                                             translucent white in every state
                                             so it reads on the dark video
                                             gradient. FluentTheme's Light
                                             variant otherwise resolves these
                                             to dark grays which disappear.
                                             Scoped here (not at Window level)
                                             so the volume slider in the
                                             popup, which sits on a theme-aware
                                             surface, isn't affected. -->
                                        <Slider.Resources>
                                            <SolidColorBrush x:Key="SliderTrackFill" Color="#80FFFFFF"/>
                                            <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#80FFFFFF"/>
                                            <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#80FFFFFF"/>
                                            <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#80FFFFFF"/>
                                        </Slider.Resources>
                                    </Slider>
                                    <TextBlock Grid.Column="1" x:Name="DurationLabel" Classes="time"
                                               Text="00:00" Margin="12,0,0,0"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="1"
                                      ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
                                    <Button Grid.Column="0" Classes="transport"
                                            Click="PlayPause_Click"
                                            Focusable="False" IsTabStop="False">
                                        <Border Classes="transport-icon">
                                            <Viewbox Width="26" Height="26">
                                                <Grid Width="24" Height="24">
                                                    <!-- Lucide play — solid filled triangle. Path's
                                                         absolute Y values nudged up by 1 grid unit so
                                                         the wide left edge feels visually centered
                                                         alongside the smaller transport icons. -->
                                                    <Path x:Name="PlayIcon"
                                                          Data="M 7.5 3.21 C 6.83 2.79 6 3.27 6 4.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"
                                                          Fill="White"/>
                                                    <!-- Lucide pause — two solid filled rounded rects
                                                         (rx=1). Drawn as one Path with two subpaths. -->
                                                    <Path x:Name="PauseIcon"
                                                          Data="M 8 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z M 16 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z"
                                                          Fill="White"
                                                          IsVisible="False"/>
                                                </Grid>
                                            </Viewbox>
                                        </Border>
                                    </Button>
                                    <Button Grid.Column="1" Classes="transport"
                                            Click="Back10_Click" Margin="2,0,0,0"
                                            Focusable="False" IsTabStop="False">
                                        <Border Classes="transport-icon">
                                            <Viewbox Width="26" Height="26">
                                                <Grid Width="24" Height="24">
                                                    <Path Data="M 3 12 a 9 9 0 1 0 3 -7.7 L 3 8 M 3 3 v 5 h 5"
                                                          Stroke="White" StrokeThickness="1.8"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Viewbox>
                                        </Border>
                                    </Button>
                                    <Button Grid.Column="2" Classes="transport"
                                            Click="Forward10_Click" Margin="2,0,0,0"
                                            Focusable="False" IsTabStop="False">
                                        <Border Classes="transport-icon">
                                            <Viewbox Width="26" Height="26">
                                                <Grid Width="24" Height="24">
                                                    <Path Data="M 21 12 a 9 9 0 1 1 -3 -7.7 L 21 8 M 21 3 v 5 h -5"
                                                          Stroke="White" StrokeThickness="1.8"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Viewbox>
                                        </Border>
                                    </Button>
                                    <Button Grid.Column="3" x:Name="MuteBtn" Classes="transport"
                                            Click="Mute_Click" Margin="2,0,0,0"
                                            Focusable="False" IsTabStop="False"
                                            PointerEntered="Mute_PointerEntered"
                                            PointerExited="Mute_PointerExited">
                                        <Border Classes="transport-icon">
                                            <Viewbox Width="26" Height="26">
                                                <Grid Width="24" Height="24">
                                                    <Path x:Name="VolumeOnIcon"
                                                          Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 15.54 8.46 a 5 5 0 0 1 0 7.07 M 19.07 4.93 a 10 10 0 0 1 0 14.14"
                                                          Stroke="White" StrokeThickness="1.8"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"/>
                                                    <Path x:Name="VolumeOffIcon"
                                                          Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 22 9 l -6 6 M 16 9 l 6 6"
                                                          Stroke="White" StrokeThickness="1.8"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"
                                                          IsVisible="False"/>
                                                </Grid>
                                            </Viewbox>
                                        </Border>
                                    </Button>
                                    <!-- Volume popup anchored to the mute button — vertical
                                         slider + percentage, Netflix-style. Stays open while
                                         the pointer is over the mute button or the popup. -->
                                    <Popup Grid.Column="3" x:Name="VolumePopup"
                                           PlacementTarget="{Binding #MuteBtn}"
                                           Placement="Top"
                                           VerticalOffset="-8"
                                           IsLightDismissEnabled="False">
                                        <Border Background="{DynamicResource ToolTipBackground}"
                                                CornerRadius="6"
                                                Padding="4"
                                                PointerEntered="VolumePopupContent_PointerEntered"
                                                PointerExited="VolumePopupContent_PointerExited">
                                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                                <TextBlock x:Name="VolumePopupText"
                                                           Text="100%"
                                                           Foreground="{DynamicResource ToolTipForeground}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"/>
                                                <Slider x:Name="VolumeSlider"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="0" Maximum="100" Value="100"
                                                        ValueChanged="Volume_Changed"
                                                        Focusable="False" IsTabStop="False"
                                                        HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    <!-- v2 — Picture-in-picture ToggleButton.
                                         Grouped with fullscreen per standard
                                         video-player conventions; swaps glyphs
                                         via {Binding IsPipActive} so it shows
                                         "Enter PiP" outside PiP and "Exit PiP"
                                         once the mini-player is up. -->
                                    <ToggleButton Grid.Column="5" x:Name="PipButton"
                                                  Classes="transport"
                                                  Focusable="False" IsTabStop="False"
                                                  Click="TogglePip_Click">
                                        <Border Classes="transport-icon">
                                            <Grid>
                                                <!-- Enter PiP — Bootstrap "bi-pip" silhouette: rounded
                                                     screen frame with a filled block in the bottom-right.
                                                     Outer 22×18 — same vertical extent as fullscreen
                                                     (y=3..21) so the icon weight matches its neighbour;
                                                     1.8 stroke same as other transport icons. Inner
                                                     block sized in Bootstrap's 37%/33% proportion with
                                                     ~2 px clearance from the inside of the stroke. -->
                                                <Viewbox Width="26" Height="26"
                                                         IsVisible="{Binding !IsPipActive}">
                                                    <Grid Width="24" Height="24">
                                                        <Rectangle Width="22" Height="18" Margin="1,3,1,3"
                                                                   RadiusX="2" RadiusY="2"
                                                                   Stroke="White" StrokeThickness="1.8"
                                                                   Fill="Transparent"/>
                                                        <Rectangle Width="8" Height="6" Margin="12,12,4,6"
                                                                   RadiusX="1" RadiusY="1"
                                                                   Fill="White"/>
                                                    </Grid>
                                                </Viewbox>
                                                <!-- Exit PiP: same enlarged outer screen + arrow pointing
                                                     into it from the bottom-right. Arrow geometry shifted
                                                     to match the new 22×18 frame. -->
                                                <Viewbox Width="26" Height="26"
                                                         IsVisible="{Binding IsPipActive}">
                                                    <Grid Width="24" Height="24">
                                                        <Rectangle Width="22" Height="18" Margin="1,3,1,3"
                                                                   RadiusX="2" RadiusY="2"
                                                                   Stroke="White" StrokeThickness="1.8"
                                                                   Fill="Transparent"/>
                                                        <Path Data="M 21 18 L 16 13 M 16 18 H 21 V 13"
                                                              Stroke="White" StrokeThickness="1.8"
                                                              StrokeLineCap="Round" StrokeJoin="Round"
                                                              Fill="Transparent"/>
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </ToggleButton>
                                    <Button Grid.Column="6" Classes="transport"
                                            Focusable="False" IsTabStop="False"
                                            Click="Fullscreen_Click">
                                        <Border Classes="transport-icon">
                                            <Viewbox Width="26" Height="26">
                                                <Grid Width="24" Height="24">
                                                    <Path Data="M 8 3 H 5 a 2 2 0 0 0 -2 2 v 3 M 21 8 V 5 a 2 2 0 0 0 -2 -2 h -3 M 3 16 v 3 a 2 2 0 0 0 2 2 h 3 M 16 21 h 3 a 2 2 0 0 0 2 -2 v -3"
                                                          Stroke="White" StrokeThickness="1.8"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Viewbox>
                                        </Border>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Recently watched view: card-styled panel shown when the
             sidebar's Recently watched button is active. Replaces the
             search content grid; previously lived inside VideoOverlayRoot.
             Card styling matches the design system (surface fill,
             rounded corners, soft shadow). -->
        <Border Grid.Row="1" x:Name="RecentlyWatchedPanel"
                IsVisible="False"
                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="6,12,6,12"
                BoxShadow="0 4 16 0 #11281E50"
                ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,18">
                    <TextBlock Text="Recently watched"
                               FontSize="22" FontWeight="Medium"
                               Margin="0,0,0,28"/>
                    <TextBlock x:Name="RecentEmptyLabel"
                               Text="Movies you have recently watched will show up here."
                               Opacity="0.7"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding Recent.Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="services:RecentWatch">
                                <Button Tag="{Binding}"
                                        Classes="recent-card"
                                        Click="RecentWatch_Click"
                                        PointerEntered="RecentCard_PointerEntered"
                                        PointerExited="RecentCard_PointerExited"
                                        Width="140" Margin="0,0,10,10"
                                        Padding="0"
                                        Background="Transparent">
                                    <StackPanel>
                                        <Grid Width="140" Height="210">
                                            <Border Background="#33000000"
                                                    CornerRadius="12"
                                                    ClipToBounds="True"
                                                    BoxShadow="0 4 16 0 #11281E50"
                                                    Cursor="Hand">
                                                <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <!-- Currently-playing scrim — darkens the
                                                 poster image (above) when this card matches
                                                 the active playback URL. ApplyRecentCardVisuals
                                                 toggles IsVisible. The title strip is drawn
                                                 after this Border, so the scrim doesn't sit
                                                 over the inline action chips. -->
                                            <Border Classes="playing-scrim"
                                                    CornerRadius="12"
                                                    Background="#80000000"
                                                    IsHitTestVisible="False"
                                                    IsVisible="False"/>
                                            <!-- Title/Source strip. Sits on top of the
                                                 image (sibling Border, drawn last) so the
                                                 play + watch-later chips inside it stay
                                                 visible. Goes fully opaque on hover via
                                                 the title-strip class style. -->
                                            <Border Classes="title-strip"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,12,12"
                                                    Padding="6,4"
                                                    Cursor="Arrow"
                                                    PointerPressed="TitleStrip_PointerPressed">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource PosterTitleTextBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Source}"
                                                               Foreground="{DynamicResource PosterSourceTextBrush}"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"/>
                                                    <!-- Action pair: play (left) + watch-later
                                                         (right). Wrapped in a StackPanel.action-row
                                                         so the row toggles IsVisible as a unit on
                                                         hover; centers the pair. -->
                                                    <StackPanel Classes="action-row"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Spacing="6">
                                                        <Button Classes="poster-chip"
                                                                Tag="{Binding}"
                                                                Click="RecentWatch_Click"
                                                                Width="32" Height="32"
                                                                Padding="0">
                                                            <Viewbox Width="22" Height="22">
                                                                <Grid Width="24" Height="24">
                                                                    <Path Classes="filled"
                                                                          Data="M 7.5 4.21 C 6.83 3.79 6 4.27 6 5.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"/>
                                                                </Grid>
                                                            </Viewbox>
                                                        </Button>
                                                        <Button Classes="poster-chip"
                                                                Tag="{Binding}"
                                                                Click="ToggleMyList_Click"
                                                                Width="32" Height="32"
                                                                Padding="0">
                                                            <Grid>
                                                                <Viewbox Width="26" Height="26"
                                                                         IsVisible="{Binding !IsInMyList}">
                                                                    <Grid Width="24" Height="24">
                                                                        <Path Data="M 12 4 V 20 M 4 12 H 20"
                                                                              StrokeThickness="2"
                                                                              StrokeLineCap="Round"
                                                                              Fill="Transparent"/>
                                                                    </Grid>
                                                                </Viewbox>
                                                                <Viewbox Width="26" Height="26"
                                                                         IsVisible="{Binding IsInMyList}">
                                                                    <Grid Width="24" Height="24">
                                                                        <Path Data="M 4 12.5 L 9 17.5 L 20 6.5"
                                                                              StrokeThickness="2"
                                                                              StrokeLineCap="Round" StrokeJoin="Round"
                                                                              Fill="Transparent"/>
                                                                    </Grid>
                                                                </Viewbox>
                                                            </Grid>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <!-- "Currently playing" badge — sibling of the
                                                 title strip (drawn after, so it sits on top
                                                 of the playing-scrim). Centered in the card
                                                 and large enough to read at a glance. Hidden
                                                 by default; ApplyRecentCardVisuals toggles
                                                 IsVisible. -->
                                            <!-- "Currently playing" badge — centered in the
                                                 top third of the card. ApplyRecentCardVisuals
                                                 toggles IsVisible. Non-interactive. -->
                                            <TextBlock Classes="playing-badge"
                                                       Text="Currently playing"
                                                       IsVisible="False"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Top"
                                                       Margin="0,52,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#CCFFFFFF"
                                                       TextAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                            <Border Classes="poster"
                                                    CornerRadius="12"
                                                    BorderThickness="2"
                                                    BorderBrush="Transparent"
                                                    IsHitTestVisible="False"/>
                                        </Grid>
                                        <Border Margin="0,4,0,0"
                                                CornerRadius="2"
                                                ClipToBounds="True">
                                            <ProgressBar Classes="recent-progress"
                                                         Value="{Binding Progress, Mode=OneWay}"
                                                         Maximum="1"
                                                         Height="3"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- My-list view: same card shell as Recently watched, items
             come from MyList.Items. The poster chip on each card lets
             the user remove an entry inline. Hidden by default. -->
        <Border Grid.Row="1" x:Name="MyListPanel"
                IsVisible="False"
                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="6,12,6,12"
                BoxShadow="0 4 16 0 #11281E50"
                ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,18">
                    <TextBlock Text="My list"
                               FontSize="22" FontWeight="Medium"
                               Margin="0,0,0,28"/>
                    <TextBlock x:Name="MyListEmptyLabel"
                               Text="Movies added to your list will show up here."
                               Opacity="0.7"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding MyList.Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="services:MyListEntry">
                                <Button Tag="{Binding}"
                                        Classes="recent-card"
                                        Click="MyListEntry_Click"
                                        PointerEntered="RecentCard_PointerEntered"
                                        PointerExited="RecentCard_PointerExited"
                                        Width="140" Margin="0,0,10,10"
                                        Padding="0"
                                        Background="Transparent">
                                    <StackPanel>
                                        <Grid Width="140" Height="210">
                                            <Border Background="#33000000"
                                                    CornerRadius="12"
                                                    ClipToBounds="True"
                                                    BoxShadow="0 4 16 0 #11281E50"
                                                    Cursor="Hand">
                                                <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <!-- Currently-playing scrim. Mirrors Recently
                                                 watched. -->
                                            <Border Classes="playing-scrim"
                                                    CornerRadius="12"
                                                    Background="#80000000"
                                                    IsHitTestVisible="False"
                                                    IsVisible="False"/>
                                            <!-- Title/Source strip — sibling of the image
                                                 Border, drawn last so the play + watch-later
                                                 chips inside it stay visible. Goes fully
                                                 opaque on hover via the title-strip class. -->
                                            <Border Classes="title-strip"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,12,12"
                                                    Padding="6,4"
                                                    Cursor="Arrow"
                                                    PointerPressed="TitleStrip_PointerPressed">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource PosterTitleTextBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Source}"
                                                               Foreground="{DynamicResource PosterSourceTextBrush}"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"/>
                                                    <!-- Action pair: play (left) + remove
                                                         (right, white check). Wrapped in a
                                                         StackPanel.action-row that toggles as
                                                         a unit on hover; centered. -->
                                                    <StackPanel Classes="action-row"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Spacing="6">
                                                        <Button Classes="poster-chip"
                                                                Tag="{Binding}"
                                                                Click="MyListEntry_Click"
                                                                Width="32" Height="32"
                                                                Padding="0">
                                                            <Viewbox Width="22" Height="22">
                                                                <Grid Width="24" Height="24">
                                                                    <Path Classes="filled"
                                                                          Data="M 7.5 4.21 C 6.83 3.79 6 4.27 6 5.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"/>
                                                                </Grid>
                                                            </Viewbox>
                                                        </Button>
                                                        <Button Classes="poster-chip"
                                                                Tag="{Binding}"
                                                                Click="MyListRemove_Click"
                                                                Width="32" Height="32"
                                                                Padding="0">
                                                            <Viewbox Width="26" Height="26">
                                                                <Grid Width="24" Height="24">
                                                                    <Path Data="M 4 12.5 L 9 17.5 L 20 6.5"
                                                                          StrokeThickness="2"
                                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                                          Fill="Transparent"/>
                                                                </Grid>
                                                            </Viewbox>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <!-- "Currently playing" badge — sibling of the
                                                 title strip; mirrors Recently watched. -->
                                            <!-- "Currently playing" badge — centered in the
                                                 top third of the card. ApplyRecentCardVisuals
                                                 toggles IsVisible. Non-interactive. -->
                                            <TextBlock Classes="playing-badge"
                                                       Text="Currently playing"
                                                       IsVisible="False"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Top"
                                                       Margin="0,52,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#CCFFFFFF"
                                                       TextAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                            <Border Classes="poster"
                                                    CornerRadius="12"
                                                    BorderThickness="2"
                                                    BorderBrush="Transparent"
                                                    IsHitTestVisible="False"/>
                                        </Grid>
                                        <Border Margin="0,4,0,0"
                                                CornerRadius="2"
                                                ClipToBounds="True">
                                            <ProgressBar Classes="recent-progress"
                                                         Value="{Binding Progress, Mode=OneWay}"
                                                         Maximum="1"
                                                         Height="3"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Settings view: embedded panel that replaces ContentGrid in
             the main area when the sidebar Settings button is clicked.
             Same content as the previous Sources flyout, just inline. -->
        <!-- Settings card: Border-wraps-ScrollViewer (matches the
             Recently watched / My list pattern) so the scrollbar lives
             inside the rounded card and inherits its 6-px right gutter. -->
        <Border Grid.Row="1" x:Name="SettingsPanel"
                IsVisible="False"
                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="6,12,6,12"
                BoxShadow="0 4 16 0 #11281E50"
                ClipToBounds="True"
                PointerPressed="SettingsBackground_PointerPressed">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SourcesFlyoutPanel"
                            Spacing="0"
                            Margin="22,18,22,18"
                            Focusable="True">
                    <!-- Header (title + subtitle), constrained width. -->
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="6">
                        <TextBlock Text="Settings" FontSize="22" FontWeight="Medium"/>
                        <TextBlock Text="Theme, search, and metadata preferences."
                                   FontSize="13"
                                   Opacity="0.7"
                                   Margin="0,0,0,28"/>
                    </StackPanel>

                    <!-- PASTEL THEMES SECTION -->
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="6">
                        <TextBlock Text="PASTEL THEMES" FontSize="11" Opacity="0.6"
                                   Margin="0,0,0,10"/>
                        <WrapPanel>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsLightLavenderRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="LightLavenderTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#9F8AE6"/>
                                    <TextBlock Text="Lavender" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsLightMintRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="LightMintTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#7DC6A6"/>
                                    <TextBlock Text="Mint" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsLightApricotRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="LightApricotTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#E8A76B"/>
                                    <TextBlock Text="Apricot" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </WrapPanel>
                    </StackPanel>

                    <!-- DARK THEMES SECTION -->
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="6"
                                Margin="0,24,0,0">
                        <TextBlock Text="DARK THEMES" FontSize="11" Opacity="0.6"
                                   Margin="0,0,0,10"/>
                        <WrapPanel>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsCatppuccinRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="CatppuccinTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#CBA6F7"/>
                                    <TextBlock Text="Catppuccin" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsDisneyPlusRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="DisneyPlusTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#0063E5"/>
                                    <TextBlock Text="Disney+" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsDraculaRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="DraculaTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#FF5555"/>
                                    <TextBlock Text="Dracula" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsNetflixRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="NetflixTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#E50914"/>
                                    <TextBlock Text="Netflix" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Classes="theme-pill"
                                         x:Name="SettingsPrimeVideoRadio"
                                         GroupName="ThemeSettings"
                                         IsCheckedChanged="PrimeVideoTheme_Checked">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Classes="swatch" Width="18" Height="18" Fill="#00A8E1"/>
                                    <TextBlock Text="Prime Video" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Full-width separator -->
                    <Separator Margin="0,24"/>

                    <!-- SEARCH SECTION (results per source + sources) -->
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="6">
                        <TextBlock Text="SEARCH" FontSize="11" Opacity="0.6"
                                   Margin="0,0,0,10"/>
                        <Grid ColumnDefinitions="*,16,Auto" VerticalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Results per source:"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="2"
                                           Classes="search-input"
                                           Value="{Binding Sources.ResultsPerSource}"
                                           Minimum="1"
                                           FormatString="0"
                                           ShowButtonSpinner="False"
                                           IsTabStop="False"
                                           KeyDown="ResultsPerSourceBox_KeyDown"
                                           ValueChanged="ResultsPerSourceBox_ValueChanged"
                                           Width="70" Height="32"/>
                        </Grid>
                        <TextBlock Text="Sources" FontSize="13" FontWeight="Medium"
                                   Margin="0,12,0,4"/>
                        <ItemsControl ItemsSource="{Binding Sources.Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="services:SourceToggle">
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding Enabled}"
                                              Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Full-width separator -->
                    <Separator Margin="0,24"/>

                    <!-- METADATA SECTION (TMDB) -->
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="6">
                        <TextBlock Text="METADATA" FontSize="11" Opacity="0.6"
                                   Margin="0,0,0,10"/>
                        <CheckBox Content="TMDB"
                                  IsChecked="{Binding Sources.TmdbEnabled}"
                                  Margin="0,2"/>
                        <TextBlock Text="TMDB API KEY" FontSize="11" Opacity="0.6"
                                   IsVisible="{Binding Sources.TmdbEnabled}"
                                   Margin="0,12,0,6"/>
                        <Grid ColumnDefinitions="*,8,Auto"
                              IsVisible="{Binding Sources.TmdbEnabled}"
                              Margin="0,0,0,4">
                            <TextBox Grid.Column="0"
                                     x:Name="TmdbKeyBox"
                                     Classes="search-input"
                                     Text="{Binding Sources.TmdbApiKey, Mode=TwoWay}"
                                     PlaceholderText="Paste your TMDB v3 key"
                                     KeyDown="TmdbKeyBox_KeyDown"/>
                            <Grid Grid.Column="2">
                                <!-- Idle: the "Check" button. Hidden after a
                                     validation completes; restored after a
                                     short delay. -->
                                <Button x:Name="TmdbValidateBtn"
                                        Classes="primary"
                                        Click="ValidateTmdbKey_Click"
                                        ToolTip.Tip="Validate key"
                                        MinWidth="80" Height="32"
                                        Padding="14,0"
                                        Content="Check"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                <!-- Result label: replaces the button with
                                     "✓ Valid" / "✗ Not valid" for ~3s, then
                                     hides itself and the button comes back. -->
                                <StackPanel x:Name="TmdbResultLabel"
                                            Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            IsVisible="False">
                                    <Viewbox Width="14" Height="14"
                                             x:Name="TmdbCheckIconHost"
                                             IsVisible="False">
                                        <Grid Width="24" Height="24">
                                            <Path Data="M 4 12 L 9 17 L 20 6"
                                                  Stroke="#3FAA63"
                                                  StrokeThickness="2.4"
                                                  StrokeLineCap="Round"
                                                  StrokeJoin="Round"
                                                  Fill="Transparent"/>
                                        </Grid>
                                    </Viewbox>
                                    <Viewbox Width="14" Height="14"
                                             x:Name="TmdbInvalidIconHost"
                                             IsVisible="False">
                                        <Grid Width="24" Height="24">
                                            <Path Data="M 6 6 L 18 18 M 18 6 L 6 18"
                                                  Stroke="#D9544D"
                                                  StrokeThickness="2.4"
                                                  StrokeLineCap="Round"
                                                  StrokeJoin="Round"
                                                  Fill="Transparent"/>
                                        </Grid>
                                    </Viewbox>
                                    <TextBlock x:Name="TmdbResultText"
                                               FontSize="14" FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <!-- Hidden legacy text indicator (kept for backwards-compat
                             with any code that pokes its Text). -->
                        <TextBlock x:Name="TmdbKeyStatusIcon" IsVisible="False"/>
                    </StackPanel>

                    <!-- Helper text — pulled out of the MaxWidth=560 column so
                         it spans the full panel width like the separators. -->
                    <TextBlock Text="Used so we can match English and German movie titles, and rank search results by relevance and accuracy."
                               FontSize="12" Opacity="0.7"
                               TextWrapping="Wrap"
                               IsVisible="{Binding Sources.TmdbEnabled}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>

    <!-- Picture-in-picture overlay: a floating mini-player that hosts the
         video while the user navigates between Search / Recently watched /
         Settings tabs. PipHost spans the entire Column 1 area (BodyGrid's
         right column) but has no Background, so empty space is click-
         transparent — only PipFrame intercepts clicks. -->
    <Grid Grid.Column="1" x:Name="PipHost">
        <Border x:Name="PipFrame"
                Width="320" Height="180"
                IsVisible="False"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="8"
                ClipToBounds="True"
                BoxShadow="0 8 24 0 #99000000"
                Background="Black"
                Cursor="SizeAll"
                PointerPressed="PipFrame_PointerPressed"
                PointerMoved="PipFrame_PointerMoved"
                PointerReleased="PipFrame_PointerReleased"
                PointerEntered="PipFrame_PointerEntered"
                PointerExited="PipFrame_PointerExited">
            <Grid>
                <!-- Mini video surface: shares the same WriteableBitmap as
                     VideoImage, so frame updates appear here automatically. -->
                <Image x:Name="PipImage" Stretch="Uniform"/>

                <!-- PiP loading spinner — same shape + accent stroke as
                     the full-size LoadingOverlay, scaled smaller for the
                     mini frame. Visibility tracks _isLoading so it shows
                     in PiP if the user dropped into mini mode while the
                     stream was still loading. -->
                <Grid x:Name="PipLoadingOverlay"
                      IsHitTestVisible="False"
                      IsVisible="False">
                    <Viewbox Width="32" Height="32"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Grid Width="24" Height="24"
                              x:Name="PipLoadingSpinner"
                              RenderTransformOrigin="50%,50%">
                            <Grid.Styles>
                                <Style Selector="Grid#PipLoadingSpinner.spinning">
                                    <Style.Animations>
                                        <Animation Duration="0:0:1"
                                                   IterationCount="INFINITE">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="RotateTransform.Angle" Value="0"/>
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="RotateTransform.Angle" Value="360"/>
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Grid.Styles>
                            <Grid.RenderTransform>
                                <RotateTransform/>
                            </Grid.RenderTransform>
                            <Path Data="M 21 12 a 9 9 0 1 1 -6.219 -8.56"
                                  Stroke="{DynamicResource SystemAccentColorBrush}"
                                  StrokeThickness="2.4"
                                  StrokeLineCap="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Grid>

                <!-- Top fading gradient: dark→transparent over ~60px so the
                     restore button sits on a readable backdrop without
                     a hard edge. Toggled with the rest of the PiP chrome. -->
                <Border x:Name="PipTopGradient"
                        VerticalAlignment="Top"
                        Height="60"
                        IsHitTestVisible="False"
                        IsVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#CC000000"/>
                            <GradientStop Offset="0.5" Color="#66000000"/>
                            <GradientStop Offset="1" Color="#00000000"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Bottom fading gradient: transparent→dark over ~80px,
                     paints behind the mini-transport so the controls are
                     readable on bright frames. -->
                <Border x:Name="PipBottomGradient"
                        VerticalAlignment="Bottom"
                        Height="80"
                        IsHitTestVisible="False"
                        IsVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#00000000"/>
                            <GradientStop Offset="0.5" Color="#66000000"/>
                            <GradientStop Offset="1" Color="#CC000000"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Mini Netflix-style HUD for the PiP frame. Same six
                     icons as the main PlayerHud, sized proportionally to
                     the PiP frame in code-behind so it stays
                     visually-consistent across PiP resizes. -->
                <Border x:Name="PipPlayerHud"
                        Width="60" Height="60"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#80000000"
                        CornerRadius="999"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                        </Transitions>
                    </Border.Transitions>
                    <Viewbox x:Name="PipHudViewbox"
                             Width="38" Height="38"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Grid Width="24" Height="24">
                            <Path x:Name="PipHudPlayIcon"
                                  Data="M 7.5 3.21 C 6.83 2.79 6 3.27 6 4.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"
                                  Fill="White"
                                  IsVisible="False"/>
                            <Path x:Name="PipHudPauseIcon"
                                  Data="M 8 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z M 16 3 a 2 2 0 0 1 2 2 V 17 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 z"
                                  Fill="White"
                                  IsVisible="False"/>
                            <Path x:Name="PipHudBackIcon"
                                  Data="M 3 12 a 9 9 0 1 0 3 -7.7 L 3 8 M 3 3 v 5 h 5"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  IsVisible="False"/>
                            <Path x:Name="PipHudForwardIcon"
                                  Data="M 21 12 a 9 9 0 1 1 -3 -7.7 L 21 8 M 21 3 v 5 h -5"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  IsVisible="False"/>
                            <Path x:Name="PipHudVolumeIcon"
                                  Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 15.54 8.46 a 5 5 0 0 1 0 7.07 M 19.07 4.93 a 10 10 0 0 1 0 14.14"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  IsVisible="False"/>
                            <Path x:Name="PipHudMuteIcon"
                                  Data="M 11 5 L 6 9 H 2 v 6 h 4 l 5 4 z M 22 9 l -6 6 M 16 9 l 6 6"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  IsVisible="False"/>
                        </Grid>
                    </Viewbox>
                </Border>

                <!-- Resize grips — corners (TR/TL/BL/BR) and edges (T/B/L/R).
                     Placed BEFORE the close/restore StackPanel and the
                     PipTransport so those interactive surfaces sit on top
                     and remain clickable; the corners take 22 px out of
                     each end of the edge grips so they don't fight for
                     hit-tests at the corners. Corner drags resize both
                     axes (free aspect / stretch); edge drags resize only
                     the dragged axis so the user can squash or stretch
                     the PiP frame independently. -->
                <Border x:Name="PipResizeGripTR"
                        Tag="TR"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="22" Height="22"
                        Background="Transparent"
                        Cursor="TopRightCorner"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripT"
                        Tag="T"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Height="6" Margin="22,0,22,0"
                        Background="Transparent"
                        Cursor="SizeNorthSouth"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripB"
                        Tag="B"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Height="6" Margin="22,0,22,0"
                        Background="Transparent"
                        Cursor="SizeNorthSouth"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripL"
                        Tag="L"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Width="6" Margin="0,22,0,22"
                        Background="Transparent"
                        Cursor="SizeWestEast"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripR"
                        Tag="R"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Width="6" Margin="0,22,0,22"
                        Background="Transparent"
                        Cursor="SizeWestEast"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>

                <!-- Top-left: restore (back to full size). Sits opposite
                     the close button so the two top-corner controls are
                     symmetrical and don't crowd each other. -->
                <Button x:Name="PipRestoreBtn"
                        Classes="back"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="6,6,0,0"
                        Width="32" Height="32"
                        Padding="0"
                        Cursor="Hand"
                        IsVisible="False"
                        Focusable="False" IsTabStop="False"
                        Click="PipRestore_Click">
                    <Viewbox Width="18" Height="18">
                        <Grid Width="24" Height="24">
                            <!-- Lucide maximize-2 (corner-out arrows). -->
                            <Path Data="M 15 3 H 21 V 9 M 9 21 H 3 V 15 M 21 3 L 14 10 M 3 21 L 10 14"
                                  Stroke="White" StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <!-- Top-right: close (tear down playback). Same
                     scale-on-hover behavior as the main video chrome
                     via Classes="back". -->
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Spacing="2"
                            Margin="0,6,6,0">
                    <Button x:Name="PipCloseBtn"
                            Classes="back"
                            Width="32" Height="32"
                            Padding="0"
                            Cursor="Hand"
                            IsVisible="False"
                            Focusable="False" IsTabStop="False"
                            Click="PipClose_Click">
                        <Viewbox Width="18" Height="18">
                            <Grid Width="24" Height="24">
                                <!-- Lucide x at 4→20 (16-unit diagonal).
                                     Slightly smaller than the 18-unit
                                     maximize-2 span next to it because
                                     the X has solid diagonal strokes
                                     across the whole icon while
                                     maximize-2 only paints the corners
                                     — at equal spans the X reads
                                     visually heavier, so the geometric
                                     inset compensates for the ink
                                     imbalance. -->
                                <Path Data="M 4 4 L 20 20 M 20 4 L 4 20"
                                      Stroke="White" StrokeThickness="1.8"
                                      StrokeLineCap="Round" StrokeJoin="Round"
                                      Fill="Transparent"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <!-- Mini transport: single row — play/pause | slider | time.
                     No solid background; the bottom gradient supplies the
                     contrast. -->
                <Border x:Name="PipTransport"
                        VerticalAlignment="Bottom"
                        Background="Transparent"
                        Padding="6,0,10,8"
                        IsVisible="False">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0"
                                Classes="back"
                                Click="PipPlayPause_Click"
                                Padding="0"
                                Width="32" Height="32"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Cursor="Hand"
                                Focusable="False" IsTabStop="False">
                            <!-- Slightly larger Viewbox (21 vs the 18 used
                                 by restore / close) so the filled
                                 play / pause shapes carry roughly the
                                 same visual weight as the bracket-style
                                 corner icons in the top-right cluster. -->
                            <Viewbox Width="21" Height="21">
                                <Grid Width="24" Height="24">
                                    <Path x:Name="PipPlayIcon"
                                          Data="M 7.5 4.21 C 6.83 3.79 6 4.27 6 5.06 v 13.88 c 0 0.79 0.83 1.27 1.5 0.85 l 11 -6.94 c 0.67 -0.42 0.67 -1.28 0 -1.7 l -11 -6.94 z"
                                          Fill="White"/>
                                    <Path x:Name="PipPauseIcon"
                                          Data="M 8 4 a 2 2 0 0 1 2 2 V 18 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 6 a 2 2 0 0 1 2 -2 z M 16 4 a 2 2 0 0 1 2 2 V 18 a 2 2 0 0 1 -2 2 a 2 2 0 0 1 -2 -2 V 6 a 2 2 0 0 1 2 -2 z"
                                          Fill="White"
                                          IsVisible="False"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Slider Grid.Column="1"
                                x:Name="PipPositionSlider"
                                Minimum="0" Maximum="1000" Value="0"
                                Focusable="False" IsTabStop="False"
                                VerticalAlignment="Center"
                                Margin="6,0,8,0">
                            <Slider.Resources>
                                <SolidColorBrush x:Key="SliderTrackFill" Color="#80FFFFFF"/>
                                <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#80FFFFFF"/>
                                <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#80FFFFFF"/>
                                <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#80FFFFFF"/>
                            </Slider.Resources>
                        </Slider>
                        <TextBlock Grid.Column="2"
                                   x:Name="PipDurationLabel"
                                   Text="00:00"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Bottom + top-left resize grips — last in the Grid so
                     they sit on top of PipTransport (which is full-width
                     transparent and would otherwise eat the corner clicks).
                     The TR grip lives earlier in the Grid (behind the
                     close/restore StackPanel) so those buttons stay
                     clickable. Each grip's Tag identifies which corner so
                     the shared handler knows which edge stays anchored. -->
                <Border x:Name="PipResizeGripTL"
                        Tag="TL"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Width="22" Height="22"
                        Background="Transparent"
                        Cursor="TopLeftCorner"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripBL"
                        Tag="BL"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Width="22" Height="22"
                        Background="Transparent"
                        Cursor="BottomLeftCorner"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
                <Border x:Name="PipResizeGripBR"
                        Tag="BR"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="22" Height="22"
                        Background="Transparent"
                        Cursor="BottomRightCorner"
                        IsVisible="False"
                        PointerPressed="PipResizeGrip_PointerPressed"
                        PointerMoved="PipResizeGrip_PointerMoved"
                        PointerReleased="PipResizeGrip_PointerReleased"/>
            </Grid>
        </Border>
    </Grid>
    </Grid>

    <!-- Status footer — full-width band at the bottom of the window.
         Same brush as the sidebar so they read as one unified surface
         (no top hairline; the column-bg color shift above the footer is
         enough of a separator and removing the line keeps the sidebar
         visually flowing into the footer with no seam on the left).
         Indented 76 px on the left so the text lines up with the
         content panels (64 sidebar + 12 RootGrid margin). -->
    <Border Grid.Row="2" x:Name="StatusFooter"
            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
            Padding="76,10,12,10">
        <TextBlock x:Name="StatusText"
                   Text="{Binding Status}"
                   Opacity="0.85"/>
    </Border>

    <!-- Theme picker modal overlay: spans the entire window so it sits
         over the title bar, sidebar and main content. Click on the
         backdrop closes; click on the card is suppressed via Handled
         in code-behind. -->
    <Grid x:Name="ThemePickerOverlay"
          Grid.RowSpan="3"
          Background="#80000000"
          IsVisible="False"
          PointerPressed="ThemePickerOverlay_BackdropClicked">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="380"
                Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24"
                BoxShadow="0 8 32 0 #66000000"
                PointerPressed="ThemePickerCard_Pressed">
            <StackPanel Spacing="6">
                <TextBlock Text="Themes" FontSize="22" FontWeight="Medium"
                           Margin="0,0,0,18"/>

                <!-- Pastel themes -->
                <TextBlock Text="Pastel themes" FontSize="13" FontWeight="Medium"
                           Margin="0,0,0,8"/>
                <WrapPanel Margin="0,0,0,12">
                    <RadioButton Classes="theme-pill"
                                 x:Name="LightLavenderThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="LightLavenderTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#9F8AE6"/>
                            <TextBlock Text="Lavender" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="LightMintThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="LightMintTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#7DC6A6"/>
                            <TextBlock Text="Mint" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="LightApricotThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="LightApricotTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#E8A76B"/>
                            <TextBlock Text="Apricot" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </WrapPanel>

                <!-- Dark themes -->
                <TextBlock Text="Dark themes" FontSize="13" FontWeight="Medium"
                           Margin="0,4,0,8"/>
                <WrapPanel>
                    <RadioButton Classes="theme-pill"
                                 x:Name="CatppuccinThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="CatppuccinTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#CBA6F7"/>
                            <TextBlock Text="Catppuccin" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="DisneyPlusThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="DisneyPlusTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#0063E5"/>
                            <TextBlock Text="Disney+" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="DraculaThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="DraculaTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#FF5555"/>
                            <TextBlock Text="Dracula" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="NetflixThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="NetflixTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#E50914"/>
                            <TextBlock Text="Netflix" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Classes="theme-pill"
                                 x:Name="PrimeVideoThemeRadio"
                                 GroupName="Theme"
                                 IsCheckedChanged="PrimeVideoTheme_Checked">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Classes="swatch" Width="18" Height="18" Fill="#00A8E1"/>
                            <TextBlock Text="Prime Video" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Window>
